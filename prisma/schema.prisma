// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  phone     String   @unique
  password  String
  name      String
  email     String?
  role      String   @default("partner")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  schedules    Schedule[]
  invoices     Invoice[]
  itemCatalogs ItemCatalog[]

  @@map("users")
}

model Schedule {
  id          String   @id @default(cuid())
  userId      String
  date        DateTime
  description String
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("schedules")
}

model Invoice {
  id            String        @id @default(cuid())
  userId        String
  invoiceNumber String?       @unique
  clientId      String?
  contractorId  String?
  projectId     String?
  representative String?
  date          DateTime      @default(now())
  dueDate       DateTime?
  projectAddress String?
  laborOnly     Boolean       @default(false)
  laborOnlyNote String?
  terms         String?
  description   String
  amount        Float         @default(0)
  subtotal      Float         @default(0)
  discountType  String        @default("FIXED")
  discountValue Float         @default(0)
  discount      Float         @default(0)
  total         Float         @default(0)
  amountPaid    Float         @default(0)
  amountDue     Float         @default(0)
  paymentStatus String        @default("UNPAID")
  status        String        @default("draft")
  pdfUrl        String?
  sentAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  client     Client?      @relation(fields: [clientId], references: [id])
  contractor Contractor?  @relation(fields: [contractorId], references: [id])
  items      InvoiceItem[]

  @@map("invoices")
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  description String
  qty         Float
  unit        String
  price       Float
  amount      Float
  sequence    Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_items")
}

model ItemCatalog {
  id           String   @id @default(cuid())
  userId       String
  description  String
  defaultUnit  String
  suggestedPrice Float  @default(0)
  usageCount   Int      @default(0)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  lastUsedAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, description, defaultUnit])
  @@map("item_catalog")
}

model Contractor {
  id        String   @id @default(cuid())
  name      String
  contact   String
  email     String?
  phone     String?
  address   String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoices Invoice[]

  @@map("contractors")
}

model Client {
  id        String   @id @default(cuid())
  name      String
  address   String
  email     String?
  phone     String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoices Invoice[]

  @@map("clients")
}
